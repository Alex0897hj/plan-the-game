generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GameStatus {
  upcoming
  cancelled
  completed
}

enum GameType {
  five_x_five
  seven_x_seven
  eight_x_eight
}

enum SurfaceType {
  artificial_turf
  natural_grass
  parquet
}


model User {
  id             Int               @id @default(autoincrement())
  email          String            @unique
  password       String
  name           String            @unique
  isAdmin        Boolean           @default(false)
  isBlocked      Boolean           @default(false)
  canCreateGame  Boolean           @default(true)
  createdAt      DateTime          @default(now())
  refreshTokens  RefreshToken[]
  games          Game[]
  participations GameParticipant[]
  chatMessages   ChatMessage[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Game {
  id           Int               @id @default(autoincrement())
  title        String
  description  String
  city         String
  gameDateTime DateTime
  gameType     GameType          @default(five_x_five)
  latitude     Float?
  longitude    Float?
  address      String?
  isIndoor     Boolean?
  surfaceType  SurfaceType?
  hasLocker    Boolean?
  hasLighting  Boolean?
  createdById  Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  status       GameStatus        @default(upcoming)
  createdBy    User              @relation(fields: [createdById], references: [id])
  participants GameParticipant[]
  chatMessages ChatMessage[]

  @@index([createdById])
  @@index([status])
  @@index([gameDateTime])
}

model GameParticipant {
  id         Int      @id @default(autoincrement())
  gameId     Int
  userId     Int
  isWaitlist Boolean  @default(false)
  createdAt  DateTime @default(now())
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([userId])
  @@index([gameId, isWaitlist])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  gameId    Int
  userId    Int
  text      String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gameId, createdAt])
}